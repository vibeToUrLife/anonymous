rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function isDeveloper(uid) {
      // Bootstrap devs are hardcoded so you can NEVER be locked out. Additional devs
      // are managed at runtime via the developers/{uid} collection (admin panel).
      return uid in [
        'HClZmAeuEaUVjHqUaFLFFMTMQnd2',
        'eUs3isAgsaRT9VLKEFI4HEFbCnk1'
      ] || exists(/databases/$(database)/documents/developers/$(uid));
    }
    // A user is blocked when a doc exists at banned/{uid}. exists() inside rules runs
    // with admin privileges, so it works regardless of the banned/ read rule.
    function isBanned(uid) {
      return exists(/databases/$(database)/documents/banned/$(uid));
    }

    // ═══════════════════════════════════════
    // 1. ROOMS — user profiles / virtual rooms
    //    Key fields: coins, pets[] (each: {id,type,name,hunger,thirst,affection,color,layer,accessory,posX,posY,parked}),
    //    plant, plantLevels, ownedPlants,
    //    ownedDecors, placedDecors, ownedWalls, wallPattern,
    //    ownedWindows, windowStyle, ownedFloors, floorStyle, ownedAccessories, plantPosition,
    //    displayName, lastCoinCollect, loginStreak, lastLoginDay,
    //    achievements, gachaPulls, giftsGiven, giftsReceived,
    //    jukeboxTrack, jukeboxVol, lastSeen, updatedAt,
    //    unlockedLayers (int 1–3), layerData (map: floor→{wallPattern,windowStyle,placedDecors,plantPosition,plant,floorStyle})
    //    NOTE: pets[].layer (int|null) assigns pet to a floor; null = unplaced, 1-3 = floor number (max 2 per floor)
    //    NOTE: pets[].posX/posY (0-1 normalized) + parked(bool) — pet dragged & dropped to a fixed spot
    //    NOTE: each floor can hold a different plant; passive revenue follows the single best-earning plant (coinRate×level)
    //    NOTE: TOTO Lottery — picks stored as totoPicks: [{drawDate,number,bet,checked,winnings,resultTier}]
    //          totoDrawDate: string (YYYY-MM-DD) — flat field for Firestore query in purchases list
    //          totoHistory: [{date,picks[],totalBet,totalWinnings}] — capped to recent entries
    //          coins are deducted on bet and added on win (owner write rules cover this)
    //    NOTE: Subway Dash (endless runner) — subwayOwnedSkins[] (string ids), subwaySelectedSkin (string),
    //          subwayOwnedEffects[] (string ids), subwaySelectedEffect (string),
    //          subwayItems: {shield,slowmo,magnet} (consumable counts). All owner-only writes;
    //          coins are spent on purchases and earned on game over via transaction.
    //    NOTE: Daily 脑筋急转弯 (brain teaser) — riddleLastSolvedDay (string YYYY-MM-DD)
    //          + riddleLastRevealedDay (string YYYY-MM-DD). Solving the day's riddle
    //          awards a flat 100 coins ONCE per day via an owner-only transaction that
    //          increments coins + sets riddleLastSolvedDay. Both day-fields are read on
    //          open to lock the riddle per-ACCOUNT (so the same account on a 2nd device
    //          can't answer again), not just per-device localStorage.
    //    NOTE: Board cosmetics & coin sinks (金币乐园) — boardCosOwned[] (cosmetic ids),
    //          boardCosEquip {color,frame,badge,title} (equipped ids), coinsSpent (number —
    //          lifetime coins burned, powers the 土豪榜 leaderboard via orderBy). Coins are
    //          spent on shop / gacha / slot / boost / awards / super-effects / fortune / burn
    //          via owner-only transactions; slot + fortune carry a house edge (coin sink).
    //          每日求签: fortuneDay (YYYY-MM-DD) + fortuneResult {tier,line,bonus} — once/day,
    //          owner-only; the stored result is shown for the rest of the day.
    //    NOTE: notifReadTs (number, ms) — per-ACCOUNT "read up to" watermark for bubble-board
    //          notifications. A message/reply with ts ≤ notifReadTs is treated as already seen,
    //          so reading on one device silences the same new-message + "tap to view" notice on
    //          the others. Owner-only write (covered by isOwner); any device reads it live.
    //    NOTE: settings {theme, fontSize, animations, walkPet, sound, notif} — per-ACCOUNT app
    //          preferences that follow the user across devices (server value wins on login;
    //          localStorage is just the instant-load cache). Owner-only write. The notif flag is
    //          a preference only — actual browser push is still gated per-device by the browser's
    //          Notification permission, so a synced "on" can't push where it was never allowed.
    // ═══════════════════════════════════════
    match /rooms/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      // - Owner may write their own room, UNLESS banned (a banned user can't earn/play).
      // - Developers (admin dashboard) may write ANY room: adjust coins, rename, reset.
      // - A signed-in (non-banned) user may add only coins/gifts/aquariumLikes to SOMEONE
      //   ELSE's room (gifting / pop rewards). The `uid != self` term is essential: without
      //   it a banned user could self-grant coins through this clause and bypass the ban.
      allow update: if (isOwner(uid) && !isBanned(uid))
                    || (isAuth() && isDeveloper(request.auth.uid))
                    || (isAuth()
                        && request.auth.uid != uid
                        && !isBanned(request.auth.uid)
                        && request.resource.data.diff(resource.data)
                           .affectedKeys()
                           .hasOnly(['coins', 'giftsReceived', 'aquariumLikes']));
      allow delete: if false;

      match /guestbook/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth()
                      && request.resource.data.fromUid == request.auth.uid;
        allow update, delete: if isAuth()
                              && resource.data.fromUid == request.auth.uid;

        match /replies/{replyId} {
          allow read: if isAuth();
          allow create: if isAuth()
                        && request.resource.data.fromUid == request.auth.uid;
          allow update, delete: if isAuth()
                                && resource.data.fromUid == request.auth.uid;
        }
      }
    }

    // ═══════════════════════════════════════
    // 2. ANSWERS — bubble board / polls
    //    replies[] items may include: {id, ts, text, image, name, reactions, replies}
    //    Optional: cos {c,f,b,t} — poster's equipped bubble cosmetics snapshot;
    //              boostUntil (ms) — paid "pin to top", any signed-in user may set it;
    //              awards {awardId: count} — paid 🏆 awards stamped on a message.
    //              (The board is anonymous, so boosting/awarding is not owner-restricted.)
    // ═══════════════════════════════════════
    match /answers/{docId} {
      allow read, write: if isAuth();
    }

    // ═══════════════════════════════════════
    // 3. FOOD SUGGESTIONS
    // ═══════════════════════════════════════
    match /food_suggestions/{docId} {
      allow read, write: if isAuth();
    }

    // ═══════════════════════════════════════
    // 4. LEADERBOARDS — UID-keyed (2048, snake, blockblast)
    // ═══════════════════════════════════════
    // Owner writes their own score; developers (admin) may correct/delete any entry.
    match /leaderboard_2048/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid) || (isAuth() && isDeveloper(request.auth.uid));
    }
    match /leaderboard_snake/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid) || (isAuth() && isDeveloper(request.auth.uid));
    }
    match /leaderboard_blockblast/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid) || (isAuth() && isDeveloper(request.auth.uid));
    }
    match /leaderboard_fishing/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid) || (isAuth() && isDeveloper(request.auth.uid));
    }
    // Subway Dash (endless runner) — UID-keyed, owner-only writes (+ developer).
    match /leaderboard_carrace/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid) || (isAuth() && isDeveloper(request.auth.uid));
    }

    // ═══════════════════════════════════════
    // 5. LEADERBOARDS — name-keyed (flappy, tetris)
    //    Doc ID = player name, not UID
    // ═══════════════════════════════════════
    match /leaderboard_flappy/{nameId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /leaderboard_tetris/{nameId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ═══════════════════════════════════════
    // 6. APP STATE — spin result, countdown
    // ═══════════════════════════════════════
    match /app_state/access_code {
      // Allow unauthenticated read for the access gate (runs before login)
      allow read: if true;
      allow write: if isAuth() && isDeveloper(request.auth.uid);
    }
    match /app_state/whats_new {
      // Anyone logged in can read; only developers can publish updates
      allow read: if isAuth();
      allow write: if isAuth() && isDeveloper(request.auth.uid);
    }
    // Site-wide maintenance switch — flipped from the admin dashboard.
    // Public read so maintenance.js can show the screen before login.
    match /app_state/maintenance {
      allow read: if true;
      allow write: if isAuth() && isDeveloper(request.auth.uid);
    }
    // Shared game state that any signed-in user legitimately writes.
    match /app_state/spin_result { allow read: if isAuth(); allow write: if isAuth(); }
    match /app_state/countdown   { allow read: if isAuth(); allow write: if isAuth(); }
    // Everything else under app_state is developer-only. This closes the old
    // blanket-write hole where this wildcard let ANY signed-in user overwrite
    // access_code / whats_new / maintenance through the OR-match semantics.
    match /app_state/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && isDeveloper(request.auth.uid);
    }

    // ═══════════════════════════════════════
    // 6a. ADMIN — bans & audit log (developer-only)
    //     banned/{uid}: the doc's existence = user is blocked. Enforced in the rooms
    //       owner-write rule (isBanned) so a banned user can't earn/play, and in the
    //       app (blocked screen + sign-out on login). Kept SEPARATE from the user's
    //       own room so a banned user can't lift their own ban.
    //     admin_log/{id}: append-only audit trail of every admin action.
    // ═══════════════════════════════════════
    match /banned/{uid} {
      allow read:  if isAuth();
      allow write: if isAuth() && isDeveloper(request.auth.uid);
    }
    // Runtime developer allowlist (in addition to the hardcoded bootstrap above).
    // Only an existing developer may grant/revoke admin access.
    match /developers/{uid} {
      allow read:  if isAuth();
      allow write: if isAuth() && isDeveloper(request.auth.uid);
    }
    match /admin_log/{logId} {
      allow read:   if isAuth() && isDeveloper(request.auth.uid);
      allow create: if isAuth() && isDeveloper(request.auth.uid);
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════
    // 6b. COIN RUSH — daily synced bubble-pop competition
    //     coin_rush/{day}/scores/{uid} — owner-only; score (pops) bounded.
    //     coin_rush/{day}/claims/{uid} — one-time top-3 bonus guard (create-only).
    //     Bounds (2000 / 20) mirror CoinRush.MAX_RUSH_SCORE / MAX_RUSH_BONUS.
    // ═══════════════════════════════════════
    match /coin_rush/{day} {
      allow read: if isAuth();

      match /scores/{uid} {
        allow read: if isAuth();
        allow write: if isOwner(uid)
                     && request.resource.data.score is number
                     && request.resource.data.score >= 0
                     && request.resource.data.score <= 2000;
        // Developers may delete entries to reset the day's competition.
        allow delete: if isAuth() && isDeveloper(request.auth.uid);
      }
      match /claims/{uid} {
        allow read: if isAuth();
        allow create: if isOwner(uid)
                      && request.resource.data.bonus is number
                      && request.resource.data.bonus >= 0
                      && request.resource.data.bonus <= 1000;
        allow update: if false;
        allow delete: if isAuth() && isDeveloper(request.auth.uid);
      }
    }

    // ═══════════════════════════════════════
    // 7. MOOD CHECK-INS
    // ═══════════════════════════════════════
    match /mood_checkins/{dateId} {
      allow read: if isAuth();
      allow write: if isAuth();

      match /voters/{odaUid} {
        allow read: if isAuth();
        allow write: if isOwner(odaUid);
      }
    }

    // ═══════════════════════════════════════
    // 8. CHESS INVITES
    // ═══════════════════════════════════════
    match /chess_invites/{inviteId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuth()
                    && (resource.data.toUid == request.auth.uid
                        || resource.data.fromUid == request.auth.uid);
      allow delete: if false;
    }

    // ═══════════════════════════════════════
    // 9. CHESS GAMES
    // ═══════════════════════════════════════
    match /chess_games/{gameId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth()
                    && resource.data.hostUid == request.auth.uid;
    }

    // ═══════════════════════════════════════
    // 10. CHESS PRESENCE
    // ═══════════════════════════════════════
    match /chess_presence/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ═══════════════════════════════════════
    // 11. DAILY RESET META
    // ═══════════════════════════════════════
    match /_meta/{docId} {
      allow read: if isAuth();
      // The daily auto-reset is run by whichever signed-in client loads first after
      // midnight; it writes ONLY the {day} marker. Restrict non-developers to exactly
      // that shape so they can't corrupt other internal state. Developers write freely.
      allow write: if (isAuth() && isDeveloper(request.auth.uid))
                   || (isAuth()
                       && request.resource.data.keys().hasOnly(['day'])
                       && request.resource.data.day is string);
    }

    // ═══════════════════════════════════════
    // 12. FEEDBACK CORNER
    // ═══════════════════════════════════════
    match /feedback/{feedbackId} {
      allow read: if isAuth();

      // Any authenticated user can create feedback
      allow create: if isAuth()
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 1000
                    && request.resource.data.status == 'pending'
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.createdAt is number;

      // Developers can update status/comments; any user can toggle votes
      allow update: if isAuth()
                    && (
                      isDeveloper(request.auth.uid)
                      || request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['votes'])
                    );

      allow delete: if false;
    }

    // ═══════════════════════════════════════
    // 13. DAILY QUOTE COMMENTS
    //     Path: quote_comments/{dateStr}/comments/{commentId}
    //     Fields: uid, displayName, text (≤200 chars), createdAt
    // ═══════════════════════════════════════
    match /quote_comments/{dateStr} {
      allow read: if isAuth();
      allow create: if isAuth();

      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth()
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() >= 1
                      && request.resource.data.text.size() <= 200
                      && request.resource.data.createdAt is number;
        allow update: if false;
        allow delete: if isAuth()
                      && (resource.data.uid == request.auth.uid
                          || isDeveloper(request.auth.uid));
      }
    }

    // ═══════════════════════════════════════
    // 14. LIVE BOARD — presence, typing & floating reactions
    //     Powers the interactive bubble board (presence.js, live-reactions.js).
    // ═══════════════════════════════════════
    // Per-user heartbeat for "who's online" + "someone is typing".
    //   Fields: lastSeen (ms), typing (bool). Anonymous — no personal data.
    //   Owner-only writes; any signed-in user may read to derive the live count.
    match /board_presence/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }
    // Single shared doc (board_reactions/live) holding a short rolling list of
    // recent reaction events {id, i}. Any signed-in user may append (arrayUnion)
    // or trim it; it is ephemeral confetti, not durable data.
    //   NOTE: Bubble Playground pops award coins to the popper's OWN rooms doc
    //   (covered by the rooms isOwner update rule); no separate collection.
    match /board_reactions/{docId} {
      allow read, write: if isAuth();
    }

    // ═══════════════════════════════════════
    // 15. DAILY RIDDLE SOLVERS — who answered today's 脑筋急转弯 correctly
    //     Path: riddle_solvers/{dateStr}/solvers/{uid} = { name, at }
    //     Powers the "🏆 今日答对" list in the riddle card (names only — the answer
    //     is NEVER stored here). Each user writes only their OWN solver doc; any
    //     signed-in user may read the list.
    // ═══════════════════════════════════════
    match /riddle_solvers/{dateStr} {
      allow read: if isAuth();
      allow create: if isAuth();

      match /solvers/{uid} {
        allow read: if isAuth();
        allow write: if isOwner(uid);
      }
    }

    // ═══════════════════════════════════════
    // 15b. DAILY RIDDLE LEADERBOARD — all-time correct-answer count per user
    //     Path: riddle_leaderboard/{uid} = { name, count, at }
    //     Powers the "🏅 答对排行榜（累计）" ranking in the riddle card. The count
    //     is only ever bumped (+1) inside the once-per-day reward transaction, so a
    //     user can raise ONLY their own total, once per day. Any signed-in user reads.
    // ═══════════════════════════════════════
    match /riddle_leaderboard/{uid} {
      allow read: if isAuth();
      allow write: if isOwner(uid);
    }

    // ═══════════════════════════════════════
    // 16. 成语 DICTIONARY — server-side word list for chain validation
    //     Path: chengyu_dict/{idiom} = {}  (doc id IS the 成语; value unused)
    //     One doc per REAL 成语. Lets the chengyu_chain rules below verify a
    //     submitted word actually exists via exists(), which blocks fake words
    //     (e.g. 诈骗集团 / 团团转转) that bypass the browser-side check. Seed it
    //     once from a developer browser session; only developers may write.
    // ═══════════════════════════════════════
    match /chengyu_dict/{idiom} {
      allow read: if isAuth();
      allow write: if isAuth() && isDeveloper(request.auth.uid);
    }

    // ═══════════════════════════════════════
    // 16b. DAILY 成语接龙 (idiom chain) — shared daily chain + who answered
    //     Path: chengyu_chain/{dateStr} = { seed, links[], wrong[] }
    //       links[] item: {w, uid, name, at}  — the chain, in order
    //       wrong[] item: {w, uid, name, reason, at}  — recent wrong attempts (≤50)
    //     ONE shared doc per day. A user appends via a transaction that also pays
    //     +20 coins to their OWN rooms doc (rooms isOwner update rule). The rules
    //     ENFORCE that each appended link is a real 成语 (exists in chengyu_dict),
    //     is 4 hanzi, and is owned by the writer — so fake idioms can't get in even
    //     by bypassing the browser. The connect (同音) check stays client-side.
    // ═══════════════════════════════════════
    match /chengyu_chain/{dateStr} {
      allow read: if isAuth();

      function newLinks() { return request.resource.data.links; }
      function oldLinks() { return resource.data.links; }
      function tailOf(list) { return list[list.size() - 1]; }
      function isRealIdiom(w) {
        return exists(/databases/$(database)/documents/chengyu_dict/$(w));
      }
      // A user-added link must be a real 成语 (exists in chengyu_dict — which only
      // holds 4-hanzi idioms) and be owned by the writer. No size() check: rules'
      // string.size() can count BYTES, so it would wrongly reject Chinese words.
      function validAnswer(link) {
        return link.w is string
               && link.uid == request.auth.uid
               && isRealIdiom(link.w);
      }

      // Developers may fix / clean the day doc freely (e.g. remove junk links).
      allow create, update: if isAuth() && isDeveloper(request.auth.uid);

      // First write of the day: seed only (size 1) or seed + one valid answer (size 2).
      allow create: if isAuth()
                    && newLinks().size() >= 1
                    && newLinks().size() <= 2
                    && (newLinks().size() == 1 || validAnswer(tailOf(newLinks())));

      allow update: if isAuth() && (
        // (a) append exactly ONE real-idiom link; previous tip must stay intact
        ( newLinks().size() == oldLinks().size() + 1
          && validAnswer(tailOf(newLinks()))
          && newLinks()[oldLinks().size() - 1] == tailOf(oldLinks()) )
        // (b) record a wrong attempt — the chain (links) must be UNCHANGED
        || newLinks() == oldLinks()
        // (c) 换开头 before anyone answered — result is a single real-idiom seed
        || ( oldLinks().size() <= 1
             && newLinks().size() == 1
             && isRealIdiom(newLinks()[0].w) )
      );

      allow delete: if false;
    }

    // ═══════════════════════════════════════
    // 17. UPCOMING EVENTS — pinned 便利贴 (sticky notes)
    //     Path: events/{autoId}
    //     Fields: uid, displayName, title (≤300 chars), eventAt (ms), createdAt (ms)
    //     Any signed-in user may pin an event; only the creator (or a developer)
    //     may delete it. A note is shown on the board until 8h past eventAt, then
    //     hidden client-side and best-effort deleted by its owner.
    // ═══════════════════════════════════════
    match /events/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() >= 1
                    && request.resource.data.title.size() <= 300
                    && request.resource.data.eventAt is number
                    && request.resource.data.createdAt is number;
      allow update: if false;
      allow delete: if isAuth()
                    && (resource.data.uid == request.auth.uid
                        || isDeveloper(request.auth.uid));
    }

    // ═══════════════════════════════════════
    // DEFAULT — deny everything else
    // ═══════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
